{
  "name": "velt/database",
  "description": "Velt Database PDO module",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-pdo": "*",
    "velt/kernel": "^0.1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Velt\\Database\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Velt\\Database\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit --colors=always"
  }
}
