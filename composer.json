{
  "name": "velt/database",
  "description": "Velt Database PDO module",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.1",
    "ext-pdo": "*",
    "velt/kernel": "dev-main"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Velt\\Database\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Velt\\Database\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../veltphp-kernel/packages/kernel",
      "options": {
        "symlink": true,
        "versions": {
          "velt/kernel": "dev-main"
        }
      }
    },
    {
      "type": "path",
      "url": "../velt-ui",
      "options": {
        "symlink": true,
        "versions": {
          "velt/ui": "dev-main"
        }
      }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit --colors=always"
  }
}
